#!/bin/bash
# pi-webcam — Raspberry Pi Webcam Management CLI v3.1
set -euo pipefail
CONFIG="/etc/rpi-webcam.conf"
REPO="https://raw.githubusercontent.com/Delulu-Delilah/rpi-uvc-webcam/main"
R='\033[0;31m';G='\033[0;32m';Y='\033[1;33m';C='\033[0;36m'
W='\033[1;37m';D='\033[2m';B='\033[0;90m';N='\033[0m'

load_config() {
    WEBCAM_PRODUCT="UVC Gadget";WEBCAM_CAMERA="other";WEBCAM_MODE="usb"
    WEBCAM_HFLIP="0";WEBCAM_VFLIP="0";WEBCAM_RES_480P="1";WEBCAM_RES_720P="1"
    WEBCAM_RES_1080P="1";WEBCAM_AUTO_UPDATE="0";WEBCAM_NETWORK_PORT="8080"
    WEBCAM_PI_MODEL="zero2w";WEBCAM_VERSION="0.0.0"
    WEBCAM_BRIGHTNESS="0.0";WEBCAM_CONTRAST="1.0";WEBCAM_SATURATION="1.0"
    WEBCAM_OVERLAY_ENABLED="0";WEBCAM_OVERLAY_TEXT="%H:%M:%S"
    WEBCAM_NIGHT_MODE="off";WEBCAM_AUTH_USER="";WEBCAM_AUTH_HASH=""
    WEBCAM_TIMELAPSE_INTERVAL="30";WEBCAM_TIMELAPSE_DIR="$HOME/timelapse"
    WEBCAM_AWB_MODE="auto";WEBCAM_AWB_RED_GAIN="1.5";WEBCAM_AWB_BLUE_GAIN="1.5"
    WEBCAM_NOISE_MODE="fast";WEBCAM_AE_MODE="normal";WEBCAM_AE_METERING="centre"
    [[ -f "$CONFIG" ]] && source "$CONFIG"
}
save_var() { local k="$1" v="$2"
    if grep -q "^${k}=" "$CONFIG" 2>/dev/null; then sudo sed -i "s|^${k}=.*|${k}=\"${v}\"|" "$CONFIG"
    else echo "${k}=\"${v}\"" | sudo tee -a "$CONFIG" >/dev/null; fi
}
cam_label() { case "${WEBCAM_CAMERA:-other}" in cam3)echo "Camera Module 3";;cam3w)echo "Cam3 Wide";;cam2)echo "Camera Module 2";;cam2noir)echo "Cam2 NoIR";;hq)echo "HQ Camera";;gs)echo "Global Shutter";;*)echo "Camera";;esac; }
rot_label() { if [[ "$WEBCAM_HFLIP$WEBCAM_VFLIP" == "11" ]];then echo "180°";elif [[ "$WEBCAM_HFLIP" == "1" ]];then echo "H-Flip";elif [[ "$WEBCAM_VFLIP" == "1" ]];then echo "V-Flip";else echo "None";fi; }
active_svc() { if systemctl is-active --quiet rpi-uvc-gadget.service 2>/dev/null;then echo "usb-active";elif systemctl is-active --quiet rpi-webcam-network.service 2>/dev/null;then echo "net-active";else echo "inactive";fi; }
cam_bin() { command -v rpicam-still &>/dev/null && echo "rpicam-still" || echo "libcamera-still"; }
cam_hello() { command -v rpicam-hello &>/dev/null && echo "rpicam-hello" || echo "libcamera-hello"; }
restart_active() { local s=$(active_svc); [[ "$s" == "usb-active" ]] && sudo systemctl restart rpi-uvc-gadget.service; [[ "$s" == "net-active" ]] && sudo systemctl restart rpi-webcam-network.service; }

# ── STATUS ──
cmd_status() { load_config; local svc=$(active_svc) ss ms
    case "$svc" in usb-active)ss="${G}● Active${N}";ms="USB Webcam";;net-active)ss="${G}● Active${N}";ms="Network · :${WEBCAM_NETWORK_PORT}";;*)ss="${R}● Inactive${N}";ms="${WEBCAM_MODE}";;esac
    local rs="";[[ "$WEBCAM_RES_480P" == "1" ]]&&rs+="480p ";[[ "$WEBCAM_RES_720P" == "1" ]]&&rs+="720p ";[[ "$WEBCAM_RES_1080P" == "1" ]]&&rs+="1080p"
    local cam_det; cam_det=$( $(cam_hello) --list-cameras 2>&1 | head -5 )
    local cam_st; [[ "$cam_det" == *"Available"* || "$cam_det" == *"imx"* || "$cam_det" == *"ov"* ]] && cam_st="${G}✓ Detected${N}" || cam_st="${R}✗ Not found${N}"
    local up="Manual";[[ "$WEBCAM_AUTO_UPDATE" == "1" ]]&&up="Auto (weekly)"
    local bar="${B}$(printf '─%.0s' {1..48})${N}"
    echo "";echo -e "  ${B}┌${bar}┐${N}"
    echo -e "  ${B}│${N}  ${W}📷  Pi Webcam${N}                                  ${B}│${N}"
    echo -e "  ${B}├${bar}┤${N}"
    printf "  ${B}│${N}  ${W}Service${N}   ${D}·····${N}  %-31b${B}│${N}\n" "$ss"
    printf "  ${B}│${N}  ${W}Mode${N}      ${D}·····${N}  %-31s${B}│${N}\n" "$ms"
    printf "  ${B}│${N}  ${W}Camera${N}    ${D}·····${N}  %-31b${B}│${N}\n" "$cam_st"
    printf "  ${B}│${N}  ${W}Device${N}    ${D}·····${N}  %-31s${B}│${N}\n" "\"${WEBCAM_PRODUCT}\""
    printf "  ${B}│${N}  ${W}Formats${N}   ${D}·····${N}  %-31s${B}│${N}\n" "${rs:-none}"
    printf "  ${B}│${N}  ${W}Rotation${N}  ${D}·····${N}  %-31s${B}│${N}\n" "$(rot_label)"
    printf "  ${B}│${N}  ${W}Updates${N}   ${D}·····${N}  %-31s${B}│${N}\n" "$up"
    echo -e "  ${B}└${bar}┘${N}";echo ""
}

# ── TEST ──
cmd_test() { load_config; local out="/tmp/pi-webcam-test.jpg" flags=""
    [[ "$WEBCAM_HFLIP" == "1" ]] && flags+=" --hflip"
    [[ "$WEBCAM_VFLIP" == "1" ]] && flags+=" --vflip"
    echo -e "${C}[INFO]${N} Capturing test image..."
    $(cam_bin) -o "$out" --width 1280 --height 720 -t 2000 --nopreview $flags 2>&1 || { echo -e "${R}✗${N} Capture failed. Check camera connection."; return 1; }
    local sz=$(stat -c%s "$out" 2>/dev/null || stat -f%z "$out" 2>/dev/null)
    echo -e "${G}✓${N} Saved: ${out} ($(( sz / 1024 )) KB)"
    echo -e "  Transfer to your computer: ${C}scp $(whoami)@$(hostname).local:${out} ./${N}"
}

# ── DIAG ──
cmd_diag() { load_config
    echo "═══ Pi Webcam Diagnostics ═══"
    echo "Date:     $(date -Iseconds)"
    echo "Hostname: $(hostname)"
    echo "User:     $(whoami)"
    echo ""
    echo "── OS ──"
    cat /etc/os-release 2>/dev/null | grep -E "^(PRETTY|VERSION)="
    echo "Kernel:   $(uname -r)"
    echo "Arch:     $(uname -m)"
    echo ""
    echo "── Camera ──"
    $(cam_hello) --list-cameras 2>&1 || echo "(camera detection failed)"
    echo ""
    echo "── USB/UDC ──"
    echo "UDC:      $(ls /sys/class/udc/ 2>/dev/null || echo 'none')"
    echo ""
    echo "── Services ──"
    for s in rpi-uvc-gadget rpi-webcam-network rpi-webcam-timelapse; do
        printf "%-30s %s\n" "$s" "$(systemctl is-active $s.service 2>/dev/null || echo 'not found')"
    done
    echo ""
    echo "── Config ──"
    cat "$CONFIG" 2>/dev/null || echo "(no config file)"
    echo ""
    echo "── System ──"
    echo "Uptime:   $(uptime -p 2>/dev/null || uptime)"
    echo "Temp:     $(vcgencmd measure_temp 2>/dev/null || echo 'N/A')"
    echo "Disk:     $(df -h / | tail -1 | awk '{print $3 "/" $2 " (" $5 " used)"}')"
    echo "Memory:   $(free -h | awk '/Mem:/{print $3 "/" $2}')"
    echo ""
    echo "── Recent Logs (20 lines) ──"
    journalctl -u rpi-uvc-gadget -u rpi-webcam-network --no-pager -n 20 --output=short-iso 2>/dev/null || echo "(no logs)"
    echo ""
    echo "═══ End Diagnostics ═══"
}

# ── ROTATE ──
cmd_rotate() { load_config; local choice="${1:-}"
    if [[ -z "$choice" ]]; then
        choice=$(whiptail --title "  Camera Rotation  " --radiolist "\nSelect orientation:\n" 16 60 5 \
            "none" "No rotation (0°)" $([[ "$WEBCAM_HFLIP$WEBCAM_VFLIP" == "00" ]]&&echo ON||echo OFF) \
            "180" "Rotate 180°" $([[ "$WEBCAM_HFLIP$WEBCAM_VFLIP" == "11" ]]&&echo ON||echo OFF) \
            "hflip" "Horizontal flip" $([[ "$WEBCAM_HFLIP$WEBCAM_VFLIP" == "10" ]]&&echo ON||echo OFF) \
            "vflip" "Vertical flip" $([[ "$WEBCAM_HFLIP$WEBCAM_VFLIP" == "01" ]]&&echo ON||echo OFF) \
            3>&1 1>&2 2>&3) || return; fi
    case "$choice" in none|0)WEBCAM_HFLIP=0;WEBCAM_VFLIP=0;;180)WEBCAM_HFLIP=1;WEBCAM_VFLIP=1;;hflip)WEBCAM_HFLIP=1;WEBCAM_VFLIP=0;;vflip)WEBCAM_HFLIP=0;WEBCAM_VFLIP=1;;*)echo "Usage: pi-webcam rotate [none|180|hflip|vflip]";return 1;;esac
    save_var WEBCAM_HFLIP "$WEBCAM_HFLIP"; save_var WEBCAM_VFLIP "$WEBCAM_VFLIP"
    echo -e "${G}✓${N} Rotation: $(rot_label)"
    local svc=$(active_svc)
    [[ "$svc" == "net-active" ]] && { sudo systemctl restart rpi-webcam-network.service; echo -e "${G}✓${N} Service restarted."; }
    [[ "$svc" == "usb-active" ]] && echo -e "${Y}⚠${N} USB mode: reboot required."
}

# ── MODE ──
cmd_mode() { load_config; local choice="${1:-}"
    if [[ -z "$choice" ]]; then
        local ip=$(hostname -I 2>/dev/null|awk '{print $1}')
        choice=$(whiptail --title "  Streaming Mode  " --radiolist "\nUSB: Plug-and-play webcam.\nNetwork: MJPEG at http://${ip:-<IP>}:${WEBCAM_NETWORK_PORT}\n" 14 65 3 \
            "usb" "USB Webcam" $([[ "$WEBCAM_MODE" == "usb" ]]&&echo ON||echo OFF) \
            "network" "Network Stream (MJPEG/HTTP)" $([[ "$WEBCAM_MODE" == "network" ]]&&echo ON||echo OFF) \
            3>&1 1>&2 2>&3) || return; fi
    save_var WEBCAM_MODE "$choice"
    case "$choice" in
        usb) sudo systemctl stop rpi-webcam-network.service 2>/dev/null||true; sudo systemctl disable rpi-webcam-network.service 2>/dev/null||true
             sudo systemctl enable rpi-uvc-gadget.service; sudo systemctl start rpi-uvc-gadget.service 2>/dev/null||true
             echo -e "${G}✓${N} USB mode.";;
        network) sudo systemctl stop rpi-uvc-gadget.service 2>/dev/null||true; sudo systemctl disable rpi-uvc-gadget.service 2>/dev/null||true
                 sudo systemctl enable rpi-webcam-network.service; sudo systemctl start rpi-webcam-network.service
                 local ip=$(hostname -I 2>/dev/null|awk '{print $1}')
                 echo -e "${G}✓${N} Network mode: ${C}http://${ip:-$(hostname).local}:${WEBCAM_NETWORK_PORT}${N}"
                 command -v qrencode &>/dev/null && qrencode -t ANSIUTF8 "http://${ip}:${WEBCAM_NETWORK_PORT}" 2>/dev/null;;
        *) echo "Usage: pi-webcam mode [usb|network]"; return 1;;
    esac
}

# ── IMAGE ──
cmd_image() { load_config; local prop="${1:-}" val="${2:-}"
    if [[ -z "$prop" ]]; then
        echo -e "  ${W}Current image settings:${N}"
        echo -e "  Brightness:  ${WEBCAM_BRIGHTNESS}"
        echo -e "  Contrast:    ${WEBCAM_CONTRAST}"
        echo -e "  Saturation:  ${WEBCAM_SATURATION}"
        echo -e "\n  Usage: pi-webcam image [brightness|contrast|saturation|reset] [value]"; return; fi
    case "$prop" in
        brightness) [[ -z "$val" ]] && { val=$(whiptail --title "Brightness" --inputbox "Range: -1.0 to 1.0" 10 50 "$WEBCAM_BRIGHTNESS" 3>&1 1>&2 2>&3)||return; }
            save_var WEBCAM_BRIGHTNESS "$val";;
        contrast) [[ -z "$val" ]] && { val=$(whiptail --title "Contrast" --inputbox "Range: 0.0 to 2.0" 10 50 "$WEBCAM_CONTRAST" 3>&1 1>&2 2>&3)||return; }
            save_var WEBCAM_CONTRAST "$val";;
        saturation) [[ -z "$val" ]] && { val=$(whiptail --title "Saturation" --inputbox "Range: 0.0 to 2.0" 10 50 "$WEBCAM_SATURATION" 3>&1 1>&2 2>&3)||return; }
            save_var WEBCAM_SATURATION "$val";;
        reset) save_var WEBCAM_BRIGHTNESS "0.0"; save_var WEBCAM_CONTRAST "1.0"; save_var WEBCAM_SATURATION "1.0"; val="defaults";;
        *) echo "Unknown: $prop"; return 1;;
    esac
    echo -e "${G}✓${N} ${prop} = ${val}"; restart_active
}

# ── AUTH ──
cmd_auth() { load_config; local action="${1:-}"
    case "$action" in
        set) read -rp "Username: " user; [[ -z "$user" ]] && { echo "Cancelled.";return; }
             read -rsp "Password: " pass; echo
             local hash=$(echo -n "$pass" | sha256sum | awk '{print $1}')
             save_var WEBCAM_AUTH_USER "$user"; save_var WEBCAM_AUTH_HASH "$hash"
             echo -e "${G}✓${N} Auth enabled for user: $user"; restart_active;;
        off) save_var WEBCAM_AUTH_USER ""; save_var WEBCAM_AUTH_HASH ""
             echo -e "${G}✓${N} Auth disabled."; restart_active;;
        *) echo -e "  ${W}Stream authentication${N}"
           [[ -n "$WEBCAM_AUTH_USER" ]] && echo -e "  Status: ${G}Enabled${N} (user: $WEBCAM_AUTH_USER)" || echo -e "  Status: ${Y}Disabled${N}"
           echo -e "\n  pi-webcam auth set    Enable with username/password"
           echo -e "  pi-webcam auth off    Disable authentication";;
    esac
}

# ── BACKUP / RESTORE ──
cmd_backup() { load_config; local dest="${1:-$HOME/pi-webcam-backup.conf}"
    cp "$CONFIG" "$dest" && echo -e "${G}✓${N} Config backed up to: $dest" || echo -e "${R}✗${N} Backup failed."; }
cmd_restore() { local src="${1:-$HOME/pi-webcam-backup.conf}"
    [[ ! -f "$src" ]] && { echo -e "${R}✗${N} File not found: $src";return 1; }
    sudo cp "$src" "$CONFIG"; echo -e "${G}✓${N} Config restored from: $src"; restart_active; }

# ── OVERLAY ──
cmd_overlay() { load_config; local action="${1:-}"
    case "$action" in
        on) save_var WEBCAM_OVERLAY_ENABLED "1"; echo -e "${G}✓${N} Overlay enabled."; restart_active;;
        off) save_var WEBCAM_OVERLAY_ENABLED "0"; echo -e "${G}✓${N} Overlay disabled."; restart_active;;
        set) shift; local txt="${*:-}";[[ -z "$txt" ]] && { txt=$(whiptail --title "Overlay Text" --inputbox "Use %H:%M:%S for time, {hostname} for hostname" 10 60 "$WEBCAM_OVERLAY_TEXT" 3>&1 1>&2 2>&3)||return; }
             save_var WEBCAM_OVERLAY_TEXT "$txt"; save_var WEBCAM_OVERLAY_ENABLED "1"
             echo -e "${G}✓${N} Overlay: $txt"; restart_active;;
        *) echo -e "  ${W}Overlay:${N} $([[ "$WEBCAM_OVERLAY_ENABLED" == "1" ]] && echo "ON — $WEBCAM_OVERLAY_TEXT" || echo "OFF")"
           echo -e "\n  pi-webcam overlay on/off/set <text>";;
    esac
}

# ── AWB ──
cmd_awb() { load_config; local mode="${1:-}"
    case "$mode" in
        "")
            echo -e "  ${W}White balance${N}"
            echo -e "    Mode:        ${WEBCAM_AWB_MODE}"
            if [[ "$WEBCAM_AWB_MODE" == "manual" ]]; then
                echo -e "    Red gain:    ${WEBCAM_AWB_RED_GAIN}"
                echo -e "    Blue gain:   ${WEBCAM_AWB_BLUE_GAIN}"
            fi
            echo -e "\n  ${W}Usage:${N}"
            echo -e "    pi-webcam awb [auto|incandescent|tungsten|fluorescent|indoor|daylight|cloudy]"
            echo -e "    pi-webcam awb manual <red_gain> <blue_gain>   (typical range 0.5–4.0)"
            return;;
        auto|incandescent|tungsten|fluorescent|indoor|daylight|cloudy)
            save_var WEBCAM_AWB_MODE "$mode"
            echo -e "${G}✓${N} White balance: ${mode}";;
        manual)
            local r="${2:-}" b="${3:-}"
            if [[ -z "$r" || -z "$b" ]]; then
                echo -e "${R}✗${N} Usage: pi-webcam awb manual <red_gain> <blue_gain>"; return 1; fi
            save_var WEBCAM_AWB_MODE "manual"
            save_var WEBCAM_AWB_RED_GAIN "$r"
            save_var WEBCAM_AWB_BLUE_GAIN "$b"
            echo -e "${G}✓${N} Manual WB: red=${r} blue=${b}";;
        *) echo -e "${R}✗${N} Unknown WB mode: $mode"; return 1;;
    esac
    restart_active
}

# ── DENOISE ──
cmd_denoise() { load_config; local mode="${1:-}"
    case "$mode" in
        "")
            echo -e "  ${W}Noise reduction${N}"
            echo -e "    Mode: ${WEBCAM_NOISE_MODE}"
            echo -e "\n  ${W}Usage:${N} pi-webcam denoise [off|fast|high|minimal]"
            echo -e "    fast     — balanced (default; good for YouTube)"
            echo -e "    high     — strongest denoise, more CPU"
            echo -e "    minimal  — light touch, preserves detail"
            echo -e "    off      — no denoise"
            return;;
        off|fast|high|minimal)
            save_var WEBCAM_NOISE_MODE "$mode"
            echo -e "${G}✓${N} Noise reduction: ${mode}";;
        *) echo -e "${R}✗${N} Unknown denoise mode: $mode"; return 1;;
    esac
    restart_active
}

# ── AE (auto-exposure) ──
cmd_ae() { load_config; local sub="${1:-}"
    case "$sub" in
        "")
            echo -e "  ${W}Auto exposure${N}"
            echo -e "    Mode:     ${WEBCAM_AE_MODE}"
            echo -e "    Metering: ${WEBCAM_AE_METERING}"
            echo -e "\n  ${W}Usage:${N}"
            echo -e "    pi-webcam ae [normal|short|long|custom]"
            echo -e "    pi-webcam ae metering [centre|spot|matrix]"
            return;;
        normal|short|long|custom)
            save_var WEBCAM_AE_MODE "$sub"
            echo -e "${G}✓${N} AE mode: ${sub}";;
        metering)
            local m="${2:-}"
            case "$m" in
                centre|spot|matrix) save_var WEBCAM_AE_METERING "$m"
                    echo -e "${G}✓${N} AE metering: ${m}";;
                *) echo -e "${R}✗${N} Usage: pi-webcam ae metering [centre|spot|matrix]"; return 1;;
            esac;;
        *) echo -e "${R}✗${N} Unknown AE option: $sub"; return 1;;
    esac
    restart_active
}

# ── NIGHT ──
cmd_night() { load_config; local mode="${1:-}"
    if [[ -z "$mode" ]]; then
        mode=$(whiptail --title "  Night Mode  " --radiolist "\nFor NoIR / low-light cameras:\n" 14 60 4 \
            "off" "Normal (daylight)" $([[ "$WEBCAM_NIGHT_MODE" == "off" ]]&&echo ON||echo OFF) \
            "on" "Night (high gain, long exposure)" $([[ "$WEBCAM_NIGHT_MODE" == "on" ]]&&echo ON||echo OFF) \
            "auto" "Auto (camera decides)" $([[ "$WEBCAM_NIGHT_MODE" == "auto" ]]&&echo ON||echo OFF) \
            3>&1 1>&2 2>&3) || return; fi
    save_var WEBCAM_NIGHT_MODE "$mode"
    echo -e "${G}✓${N} Night mode: $mode"; restart_active
}

# ── TIMELAPSE ──
cmd_timelapse() { load_config; local action="${1:-status}"
    case "$action" in
        start) local intv="${2:-$WEBCAM_TIMELAPSE_INTERVAL}" dir="${3:-$WEBCAM_TIMELAPSE_DIR}"
            mkdir -p "$dir"; save_var WEBCAM_TIMELAPSE_INTERVAL "$intv"; save_var WEBCAM_TIMELAPSE_DIR "$dir"
            sudo systemctl start rpi-webcam-timelapse.service 2>/dev/null||true
            echo -e "${G}✓${N} Timelapse: every ${intv}s → ${dir}";;
        stop) sudo systemctl stop rpi-webcam-timelapse.service 2>/dev/null||true
            echo -e "${G}✓${N} Timelapse stopped.";;
        status) if systemctl is-active --quiet rpi-webcam-timelapse.service 2>/dev/null; then
                local cnt=$(ls "$WEBCAM_TIMELAPSE_DIR"/*.jpg 2>/dev/null|wc -l)
                echo -e "  Timelapse: ${G}Running${N} (${cnt} frames in ${WEBCAM_TIMELAPSE_DIR})"
            else echo -e "  Timelapse: ${D}Stopped${N}"; fi
            echo -e "\n  pi-webcam timelapse start [interval_sec] [output_dir]"
            echo -e "  pi-webcam timelapse stop";;
    esac
}

# ── TAILSCALE ──
cmd_tailscale() {
    if command -v tailscale &>/dev/null; then
        local ts_ip=$(tailscale ip -4 2>/dev/null || echo "unknown")
        echo -e "  ${G}✓${N} Tailscale installed"
        echo -e "  Tailscale IP: ${C}${ts_ip}${N}"
        load_config
        [[ "$WEBCAM_MODE" == "network" ]] && echo -e "  Stream:      ${C}http://${ts_ip}:${WEBCAM_NETWORK_PORT}${N}"
    else
        echo -e "  ${Y}Tailscale not installed.${N}"
        echo -e "  Install: ${C}curl -fsSL https://tailscale.com/install.sh | sh${N}"
        echo -e "  Then:    ${C}sudo tailscale up${N}"
    fi
}

# ── WIFI ──
cmd_wifi() { local action="${1:-status}"
    case "$action" in
        status) if command -v nmcli &>/dev/null; then
                echo -e "  ${W}WiFi Status:${N}"; nmcli -t -f active,ssid,signal dev wifi list 2>/dev/null | grep "^yes" | awk -F: '{printf "  SSID: %s  Signal: %s%%\n",$2,$3}'
            else echo -e "  SSID: $(iwgetid -r 2>/dev/null||echo unknown)"; fi;;
        connect) if command -v nmcli &>/dev/null; then
                echo -e "${C}[INFO]${N} Scanning..."; local ssid
                ssid=$(nmcli -t -f SSID dev wifi list 2>/dev/null | sort -u | grep -v '^$' | \
                    nl -ba | whiptail --title "  Select WiFi  " --menu "Choose network:" 18 60 10 $(cat) 3>&1 1>&2 2>&3) || return
                read -rsp "Password for ${ssid}: " pw; echo
                nmcli dev wifi connect "$ssid" password "$pw" && echo -e "${G}✓${N} Connected to ${ssid}" || echo -e "${R}✗${N} Connection failed."
            else echo -e "${Y}nmcli not available.${N} Edit /etc/wpa_supplicant/wpa_supplicant.conf manually."; fi;;
        *) echo -e "  pi-webcam wifi status    Show current connection"
           echo -e "  pi-webcam wifi connect   Connect to a new network";;
    esac
}

# ── UPDATE ──
cmd_update() { case "${1:-}" in
    --auto-on) save_var WEBCAM_AUTO_UPDATE "1"; sudo systemctl enable --now rpi-webcam-update.timer 2>/dev/null||true; echo -e "${G}✓${N} Auto-updates on.";return;;
    --auto-off) save_var WEBCAM_AUTO_UPDATE "0"; sudo systemctl disable --now rpi-webcam-update.timer 2>/dev/null||true; echo -e "${G}✓${N} Auto-updates off.";return;;esac
    echo -e "${C}[INFO]${N} Checking..."; load_config
    local latest; latest=$(curl -sSL "${REPO}/VERSION" 2>/dev/null|head -1)||{ echo -e "${R}✗${N} Cannot reach server.";return 1; }
    local current="${WEBCAM_VERSION:-0.0.0}"
    [[ "$latest" == "$current" ]] && { echo -e "${G}✓${N} Up to date (v${current}).";return; }
    echo -e "${Y}⟳${N} v${current} → v${latest}"; read -rp "Install? [y/N] " yn; [[ ! "$yn" =~ ^[Yy] ]] && return
    local tmp=$(mktemp); curl -sSL "${REPO}/install-rpi-webcam.sh" -o "$tmp"; bash "$tmp" --update; rm -f "$tmp"
}
cmd_config() { local tmp=$(mktemp); curl -sSL "${REPO}/install-rpi-webcam.sh" -o "$tmp"; bash "$tmp"; rm -f "$tmp"; }
cmd_logs() { local n="${1:-50}"; journalctl -u rpi-uvc-gadget -u rpi-webcam-network -u rpi-webcam-timelapse --no-pager -n "$n" --output=short-iso 2>/dev/null||echo "No logs."; }

# ── HELP ──
cmd_help() { echo ""
    echo -e "  ${W}📷  pi-webcam${N} — Raspberry Pi Webcam Manager"
    echo -e "\n  ${C}STREAMING${N}"
    echo -e "    ${W}status${N}                    Show current status"
    echo -e "    ${W}mode${N}   [usb|network]      Switch streaming mode"
    echo -e "    ${W}test${N}                      Capture test image"
    echo -e "\n  ${C}CAMERA${N}"
    echo -e "    ${W}rotate${N} [0|180|hflip|vflip]  Camera rotation"
    echo -e "    ${W}image${N}  [brightness|contrast|saturation|reset] [val]"
    echo -e "    ${W}awb${N}    [auto|incandescent|fluorescent|daylight|cloudy|manual <r> <b>]  White balance"
    echo -e "    ${W}denoise${N} [off|fast|high|minimal]  Noise reduction"
    echo -e "    ${W}ae${N}     [normal|short|long|custom] [metering centre|spot|matrix]  Auto exposure"
    echo -e "    ${W}night${N}  [off|on|auto]      Night / low-light mode"
    echo -e "    ${W}overlay${N} [on|off|set <text>] Text overlay on stream"
    echo -e "\n  ${C}CAPTURE${N}"
    echo -e "    ${W}timelapse${N} [start|stop|status]  Timelapse capture"
    echo -e "\n  ${C}NETWORK${N}"
    echo -e "    ${W}auth${N}   [set|off]          Stream password protection"
    echo -e "    ${W}wifi${N}   [status|connect]   WiFi management"
    echo -e "    ${W}tailscale${N}                 Tailscale VPN status"
    echo -e "\n  ${C}SYSTEM${N}"
    echo -e "    ${W}update${N} [--auto-on|off]    Check for updates"
    echo -e "    ${W}config${N}                    Re-run setup wizard"
    echo -e "    ${W}diag${N}                      Diagnostics report"
    echo -e "    ${W}backup${N}  [path]            Backup configuration"
    echo -e "    ${W}restore${N} [path]            Restore configuration"
    echo -e "    ${W}logs${N}    [N]               Service logs"; echo ""
}

case "${1:-help}" in
    status)cmd_status;;rotate)shift;cmd_rotate "$@";;mode)shift;cmd_mode "$@";;
    test)cmd_test;;diag)cmd_diag;;image)shift;cmd_image "$@";;auth)shift;cmd_auth "$@";;
    backup)shift;cmd_backup "$@";;restore)shift;cmd_restore "$@";;
    overlay)shift;cmd_overlay "$@";;night)shift;cmd_night "$@";;
    awb)shift;cmd_awb "$@";;denoise)shift;cmd_denoise "$@";;ae)shift;cmd_ae "$@";;
    timelapse)shift;cmd_timelapse "$@";;tailscale)cmd_tailscale;;wifi)shift;cmd_wifi "$@";;
    update)shift;cmd_update "$@";;config)cmd_config;;logs)shift;cmd_logs "$@";;
    help|--help|-h)cmd_help;;*)echo "Unknown: $1";cmd_help;exit 1;;
esac
