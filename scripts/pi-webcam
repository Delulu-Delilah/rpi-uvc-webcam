#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# pi-webcam — Raspberry Pi Webcam Management CLI
# ═══════════════════════════════════════════════════════════════
set -euo pipefail

CONFIG="/etc/rpi-webcam.conf"
REPO="https://raw.githubusercontent.com/Delulu-Delilah/rpi-uvc-webcam/main"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'
W='\033[1;37m'; D='\033[2m'; B='\033[0;90m'; N='\033[0m'

load_config() {
    WEBCAM_PRODUCT="UVC Gadget"; WEBCAM_CAMERA="other"
    WEBCAM_MODE="usb"; WEBCAM_HFLIP="0"; WEBCAM_VFLIP="0"
    WEBCAM_RES_480P="1"; WEBCAM_RES_720P="1"; WEBCAM_RES_1080P="1"
    WEBCAM_AUTO_UPDATE="0"; WEBCAM_NETWORK_PORT="8080"
    WEBCAM_PI_MODEL="zero2w"; WEBCAM_VERSION="0.0.0"
    [[ -f "$CONFIG" ]] && source "$CONFIG"
}

save_config_var() {
    local key="$1" val="$2"
    if grep -q "^${key}=" "$CONFIG" 2>/dev/null; then
        sudo sed -i "s|^${key}=.*|${key}=\"${val}\"|" "$CONFIG"
    else
        echo "${key}=\"${val}\"" | sudo tee -a "$CONFIG" >/dev/null
    fi
}

cam_label() {
    case "${WEBCAM_CAMERA:-other}" in
        cam3) echo "Camera Module 3";; cam3w) echo "Camera Module 3 Wide";;
        cam2) echo "Camera Module 2";; cam2noir) echo "Camera Module 2 NoIR";;
        hq) echo "HQ Camera";; gs) echo "Global Shutter";; *) echo "Camera";;
    esac
}

rotation_label() {
    if [[ "${WEBCAM_HFLIP}" == "1" && "${WEBCAM_VFLIP}" == "1" ]]; then echo "180°"
    elif [[ "${WEBCAM_HFLIP}" == "1" ]]; then echo "H-Flip"
    elif [[ "${WEBCAM_VFLIP}" == "1" ]]; then echo "V-Flip"
    else echo "None"; fi
}

active_service() {
    if systemctl is-active --quiet rpi-uvc-gadget.service 2>/dev/null; then echo "usb-active"
    elif systemctl is-active --quiet rpi-webcam-network.service 2>/dev/null; then echo "net-active"
    else echo "inactive"; fi
}

# ── STATUS ────────────────────────────────────────────────────
cmd_status() {
    load_config
    local svc=$(active_service)
    local status_str mode_str

    case "$svc" in
        usb-active) status_str="${G}● Active${N}"; mode_str="USB Webcam";;
        net-active)  status_str="${G}● Active${N}"; mode_str="Network · :${WEBCAM_NETWORK_PORT}";;
        *)           status_str="${R}● Inactive${N}"; mode_str="${WEBCAM_MODE:-usb}";;
    esac

    local res=""
    [[ "${WEBCAM_RES_480P}" == "1" ]] && res+="480p "
    [[ "${WEBCAM_RES_720P}" == "1" ]] && res+="720p "
    [[ "${WEBCAM_RES_1080P}" == "1" ]] && res+="1080p "
    local rot=$(rotation_label)
    local upd="Manual"
    [[ "${WEBCAM_AUTO_UPDATE}" == "1" ]] && upd="Auto (weekly)"

    local bar="${B}$(printf '─%.0s' {1..48})${N}"
    echo ""
    echo -e "  ${B}┌${bar}┐${N}"
    echo -e "  ${B}│${N}  ${W}📷  Pi Webcam${N}                                  ${B}│${N}"
    echo -e "  ${B}├${bar}┤${N}"
    printf  "  ${B}│${N}  ${W}Service${N}   ${D}·······${N}  %-30b${B}│${N}\n" "$status_str"
    printf  "  ${B}│${N}  ${W}Mode${N}      ${D}·······${N}  %-30s${B}│${N}\n" "$mode_str"
    printf  "  ${B}│${N}  ${W}Camera${N}    ${D}·······${N}  %-30s${B}│${N}\n" "$(cam_label)"
    printf  "  ${B}│${N}  ${W}Device${N}    ${D}·······${N}  %-30s${B}│${N}\n" "\"${WEBCAM_PRODUCT}\""
    printf  "  ${B}│${N}  ${W}Formats${N}   ${D}·······${N}  %-30s${B}│${N}\n" "${res:-none}"
    printf  "  ${B}│${N}  ${W}Rotation${N}  ${D}·······${N}  %-30s${B}│${N}\n" "$rot"
    printf  "  ${B}│${N}  ${W}Updates${N}   ${D}·······${N}  %-30s${B}│${N}\n" "$upd"
    echo -e "  ${B}└${bar}┘${N}"
    echo ""
}

# ── ROTATE ────────────────────────────────────────────────────
cmd_rotate() {
    load_config
    local choice="${1:-}"

    if [[ -z "$choice" ]]; then
        choice=$(whiptail --title "  Camera Rotation  " --radiolist \
            "\nSelect the orientation correction.\n0° and 180° work in both USB and Network mode.\n" \
            16 60 5 \
            "none"  "No rotation (0°)" $([[ "${WEBCAM_HFLIP}" == "0" && "${WEBCAM_VFLIP}" == "0" ]] && echo ON || echo OFF) \
            "180"   "Rotate 180°"      $([[ "${WEBCAM_HFLIP}" == "1" && "${WEBCAM_VFLIP}" == "1" ]] && echo ON || echo OFF) \
            "hflip" "Horizontal flip"  $([[ "${WEBCAM_HFLIP}" == "1" && "${WEBCAM_VFLIP}" == "0" ]] && echo ON || echo OFF) \
            "vflip" "Vertical flip"    $([[ "${WEBCAM_HFLIP}" == "0" && "${WEBCAM_VFLIP}" == "1" ]] && echo ON || echo OFF) \
            3>&1 1>&2 2>&3) || return
    fi

    case "$choice" in
        none|0)   WEBCAM_HFLIP=0; WEBCAM_VFLIP=0;;
        180)      WEBCAM_HFLIP=1; WEBCAM_VFLIP=1;;
        hflip)    WEBCAM_HFLIP=1; WEBCAM_VFLIP=0;;
        vflip)    WEBCAM_HFLIP=0; WEBCAM_VFLIP=1;;
        *) echo "Usage: pi-webcam rotate [none|180|hflip|vflip]"; return 1;;
    esac

    save_config_var WEBCAM_HFLIP "$WEBCAM_HFLIP"
    save_config_var WEBCAM_VFLIP "$WEBCAM_VFLIP"

    echo -e "${G}✓${N} Rotation set to: $(rotation_label)"

    # Restart active service
    local svc=$(active_service)
    if [[ "$svc" == "net-active" ]]; then
        sudo systemctl restart rpi-webcam-network.service
        echo -e "${G}✓${N} Network service restarted."
    elif [[ "$svc" == "usb-active" ]]; then
        echo -e "${Y}⚠${N} USB mode rotation requires a reboot to take effect."
        read -rp "Reboot now? [y/N] " yn
        [[ "$yn" =~ ^[Yy] ]] && sudo reboot
    fi
}

# ── MODE ──────────────────────────────────────────────────────
cmd_mode() {
    load_config
    local choice="${1:-}"

    if [[ -z "$choice" ]]; then
        local ip=$(hostname -I 2>/dev/null | awk '{print $1}')
        choice=$(whiptail --title "  Streaming Mode  " --radiolist \
            "\nUSB: Acts as a plug-and-play webcam via USB cable.\nNetwork: Streams MJPEG over HTTP at http://${ip:-<IP>}:${WEBCAM_NETWORK_PORT}\n" \
            14 65 3 \
            "usb"     "USB Webcam (plug-and-play)" $([[ "${WEBCAM_MODE}" == "usb" ]] && echo ON || echo OFF) \
            "network" "Network Stream (MJPEG/HTTP)" $([[ "${WEBCAM_MODE}" == "network" ]] && echo ON || echo OFF) \
            3>&1 1>&2 2>&3) || return
    fi

    case "$choice" in
        usb)
            save_config_var WEBCAM_MODE "usb"
            sudo systemctl stop rpi-webcam-network.service 2>/dev/null || true
            sudo systemctl disable rpi-webcam-network.service 2>/dev/null || true
            sudo systemctl enable rpi-uvc-gadget.service
            sudo systemctl start rpi-uvc-gadget.service 2>/dev/null || true
            echo -e "${G}✓${N} Switched to USB webcam mode."
            ;;
        network)
            save_config_var WEBCAM_MODE "network"
            sudo systemctl stop rpi-uvc-gadget.service 2>/dev/null || true
            sudo systemctl disable rpi-uvc-gadget.service 2>/dev/null || true
            sudo systemctl enable rpi-webcam-network.service
            sudo systemctl start rpi-webcam-network.service
            local ip=$(hostname -I 2>/dev/null | awk '{print $1}')
            echo -e "${G}✓${N} Switched to network streaming mode."
            echo -e "  Stream: ${C}http://${ip:-$(hostname).local}:${WEBCAM_NETWORK_PORT}${N}"
            ;;
        *) echo "Usage: pi-webcam mode [usb|network]"; return 1;;
    esac
}

# ── UPDATE ────────────────────────────────────────────────────
cmd_update() {
    case "${1:-}" in
        --auto-on)
            save_config_var WEBCAM_AUTO_UPDATE "1"
            sudo systemctl enable --now rpi-webcam-update.timer 2>/dev/null || true
            echo -e "${G}✓${N} Auto-updates enabled (weekly)."
            return;;
        --auto-off)
            save_config_var WEBCAM_AUTO_UPDATE "0"
            sudo systemctl disable --now rpi-webcam-update.timer 2>/dev/null || true
            echo -e "${G}✓${N} Auto-updates disabled."
            return;;
    esac

    echo -e "${C}[INFO]${N} Checking for updates..."
    local latest
    latest=$(curl -sSL "${REPO}/VERSION" 2>/dev/null | head -1) || { echo -e "${R}✗${N} Cannot reach update server."; return 1; }
    load_config
    local current="${WEBCAM_VERSION:-0.0.0}"

    if [[ "$latest" == "$current" ]]; then
        echo -e "${G}✓${N} Already up to date (v${current})."
        return
    fi

    echo -e "${Y}⟳${N} Update available: v${current} → v${latest}"
    read -rp "Install update now? [y/N] " yn
    [[ ! "$yn" =~ ^[Yy] ]] && return

    echo -e "${C}[INFO]${N} Downloading installer..."
    local tmp=$(mktemp)
    curl -sSL "${REPO}/install-rpi-webcam.sh" -o "$tmp"
    bash "$tmp" --update
    rm -f "$tmp"
}

# ── CONFIG ────────────────────────────────────────────────────
cmd_config() {
    echo -e "${C}[INFO]${N} Launching installer wizard..."
    local tmp=$(mktemp)
    curl -sSL "${REPO}/install-rpi-webcam.sh" -o "$tmp"
    bash "$tmp"
    rm -f "$tmp"
}

# ── LOGS ──────────────────────────────────────────────────────
cmd_logs() {
    local lines="${1:-50}"
    echo -e "${C}── Service Logs (last ${lines} lines) ──${N}"
    journalctl -u rpi-uvc-gadget.service -u rpi-webcam-network.service \
        --no-pager -n "$lines" --output=short-iso 2>/dev/null || \
        echo "No logs available."
}

# ── HELP ──────────────────────────────────────────────────────
cmd_help() {
    echo ""
    echo -e "  ${W}📷  pi-webcam${N} — Raspberry Pi Webcam Manager"
    echo ""
    echo -e "  ${C}COMMANDS${N}"
    echo -e "    ${W}status${N}              Show current webcam status"
    echo -e "    ${W}mode${N}   [usb|network] Switch streaming mode"
    echo -e "    ${W}rotate${N} [0|180|hflip|vflip]  Set camera rotation"
    echo -e "    ${W}update${N}              Check for & install updates"
    echo -e "    ${W}update --auto-on${N}    Enable weekly auto-updates"
    echo -e "    ${W}update --auto-off${N}   Disable auto-updates"
    echo -e "    ${W}config${N}              Re-run setup wizard"
    echo -e "    ${W}logs${N}   [N]          Show last N service log lines"
    echo -e "    ${W}help${N}                Show this help"
    echo ""
}

# ── MAIN ──────────────────────────────────────────────────────
case "${1:-help}" in
    status) cmd_status;;
    rotate) shift; cmd_rotate "$@";;
    mode)   shift; cmd_mode "$@";;
    update) shift; cmd_update "$@";;
    config) cmd_config;;
    logs)   shift; cmd_logs "$@";;
    help|--help|-h) cmd_help;;
    *) echo "Unknown command: $1"; cmd_help; exit 1;;
esac
